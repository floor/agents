# Git (required)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org

# Task adapter: "linear" (default) or "things"
TASK_ADAPTER=linear
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...
LINEAR_PROJECT_ID=...              # optional — filter issues to a specific project

# LLM providers (only needed for providers referenced in your agent config)
ANTHROPIC_API_KEY=sk-ant-...

# LM Studio (local models — no API key needed by default)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# OpenAI-compatible (OpenAI, Ollama, Together, Groq, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional
CONFIG_PATH=./config/templates/default.yaml
STATE_DIR=./data/executions
